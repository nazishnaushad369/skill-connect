# Django secret key — generate a strong random one for production
SECRET_KEY=skillconnect-super-secret-change-this

# Set to False in production
DEBUG=False

# Comma-separated list — add your Render backend domain
ALLOWED_HOSTS=skillconnect-backend.onrender.com,localhost,127.0.0.1

# PostgreSQL connection string — Render sets this automatically
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated frontend origins
CORS_ALLOWED_ORIGINS=https://skillconnect-app.vercel.app,http://localhost:5173
